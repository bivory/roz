{
  "description": "roz quality gate hooks - enforces independent review before task completion",
  "hooks": {
    "SessionStart": [{
      "hooks": [{
        "type": "command",
        "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/roz\" hook session-start",
        "timeout": 5
      }]
    }],
    "PreToolUse": [
      {
        "matcher": "mcp__tissue__.*",
        "hooks": [{
          "type": "command",
          "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/roz\" hook pre-tool-use",
          "timeout": 5
        }]
      },
      {
        "matcher": "mcp__beads__.*",
        "hooks": [{
          "type": "command",
          "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/roz\" hook pre-tool-use",
          "timeout": 5
        }]
      },
      {
        "matcher": "Bash",
        "hooks": [{
          "type": "command",
          "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/roz\" hook pre-tool-use",
          "timeout": 5
        }]
      }
    ],
    "Stop": [{
      "hooks": [{
        "type": "command",
        "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/roz\" hook stop",
        "timeout": 5
      }]
    }],
    "SubagentStop": [{
      "matcher": "roz:roz",
      "hooks": [{
        "type": "command",
        "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/roz\" hook subagent-stop",
        "timeout": 5
      }]
    }],
    "UserPromptSubmit": [{
      "hooks": [{
        "type": "command",
        "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/roz\" hook user-prompt",
        "timeout": 5
      }]
    }]
  }
}
